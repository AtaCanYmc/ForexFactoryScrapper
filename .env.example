# .env.example - copy to .env and edit values as needed
# Host and port the Flask app will bind to
HOST=127.0.0.1
PORT=5000

# DEBUG: True/False (or 1/0)
DEBUG=True

# Optional: specify a custom dotenv path
# DOTENV_PATH=/full/path/to/.env

# ClassNames
TIME=calendar__time
CURRENCY=calendar__currency
PREVIOUS=calendar__previous
ACTUAL=calendar__actual
FORECAST=calendar__forecast
IMPACT=calendar__impact
EVENT=calendar__event

# Attribute for unique event identifier
ROW_ID=data-event-id
